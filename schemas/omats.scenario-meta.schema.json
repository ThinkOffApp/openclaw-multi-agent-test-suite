{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thinkoff.io/schemas/omats.scenario-meta.schema.json",
  "title": "OMATS Scenario Metadata",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "scenario_id",
    "stage",
    "title"
  ],
  "properties": {
    "schema_version": {
      "const": "omats.scenario-meta.v1"
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "requires": {
      "type": "object"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
