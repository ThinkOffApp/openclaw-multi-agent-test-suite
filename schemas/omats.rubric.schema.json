{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thinkoff.io/schemas/omats.rubric.schema.json",
  "title": "OMATS Rubric",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "scenario_id",
    "pass_conditions",
    "fail_conditions"
  ],
  "properties": {
    "schema_version": {
      "const": "omats.rubric.v1"
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "pass_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fail_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "auto_fail": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "noise_penalties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "deduct"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "deduct": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "dimensions": {
      "type": "object",
      "required": ["comprehension", "discipline", "execution"],
      "properties": {
        "comprehension": { "type": "string", "minLength": 1 },
        "discipline": { "type": "string", "minLength": 1 },
        "execution": { "type": "string", "minLength": 1 }
      }
    },
    "scoring_notes": {
      "type": "string"
    }
  }
}
