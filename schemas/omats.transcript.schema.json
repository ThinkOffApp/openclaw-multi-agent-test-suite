{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thinkoff.io/schemas/omats.transcript.schema.json",
  "title": "OMATS Transcript",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "participants",
    "events"
  ],
  "properties": {
    "schema_version": {
      "const": "omats.transcript.v1"
    },
    "system_prompt": {
      "type": "string"
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "role"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "enum": ["human", "scripted-agent", "model-under-test"]
          }
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["id", "type", "from", "body"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "const": "message" },
              "from": { "type": "string", "minLength": 1 },
              "body": { "type": "string", "minLength": 1 },
              "note": { "type": "string" }
            }
          },
          {
            "type": "object",
            "required": ["id", "type", "from", "note"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "const": "expect-response" },
              "from": { "type": "string", "minLength": 1 },
              "note": { "type": "string", "minLength": 1 }
            }
          },
          {
            "type": "object",
            "required": ["id", "type", "tool", "result"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "const": "tool-result" },
              "tool": { "type": "string", "minLength": 1 },
              "result": { "type": "object" },
              "note": { "type": "string" }
            }
          },
          {
            "type": "object",
            "required": ["id", "type", "count", "template"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "const": "filler-block" },
              "count": { "type": "integer", "minimum": 1 },
              "template": {
                "type": "object",
                "required": ["from", "body_pattern"],
                "properties": {
                  "from": { "type": "string", "minLength": 1 },
                  "body_pattern": { "type": "string", "minLength": 1 }
                }
              },
              "note": { "type": "string" }
            }
          }
        ]
      }
    }
  }
}
